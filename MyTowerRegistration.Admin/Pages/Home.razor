@* =============================================================================
   HOME.RAZOR — Dashboard Landing Page

   @page "/" declares the route for this component. The Router in App.razor
   scans the assembly for these directives at startup — no central route table.

   Multiple @page directives on one component = multiple routes for the same page:
     @page "/"
     @page "/home"
   Both would render this component — useful for aliases.
   ============================================================================= *@

@page "/"

<PageTitle>MyTower Admin</PageTitle>

<h1>MyTower Admin</h1>

<p class="lead">Management interface for the MyTower registration API.</p>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Users</h5>
                <p class="card-text">View all registered users.</p>
                <a href="users" class="btn btn-primary">View Users</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Register User</h5>
                <p class="card-text">Create a new user account.</p>
                <a href="register" class="btn btn-success">Register</a>
            </div>
        </div>
    </div>
</div>
