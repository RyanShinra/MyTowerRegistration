@* =============================================================================
   REGISTER.RAZOR — New User Registration Form

   What changed from the raw HttpClient version:
     - @inject HttpClient Http  →  @inject IMyTowerClient Client
     - Manual JSON POST + string mutation  →  Client.RegisterUser.ExecuteAsync(input)
     - Hand-written CreateUserResult, RegisterUserPayload records  →  generated types
     - No [JsonPropertyName], no silent-null deserialization bugs

   Blazor forms use EditForm (not plain HTML <form>) to get:
     - Two-way data binding via @bind
     - Built-in validation via DataAnnotationsValidator
     - Structured submit handling via OnValidSubmit / OnInvalidSubmit

   The model bound to the form is a plain C# class (RegisterForm below).
   Data annotations on that class drive validation — same attributes you'd
   use on an EF Core entity or an ASP.NET MVC model.

   Compare to React: controlled components with useState for each field,
   or a form library like React Hook Form. Blazor's EditForm is closer to
   the latter — it manages field state and validation in one place.
   ============================================================================= *@

@page "/register"
@inject IMyTowerClient Client
@* NavigationManager used to redirect to /users after successful registration *@
@inject NavigationManager Nav

<PageTitle>Register User — MyTower Admin</PageTitle>

<h1>Register User</h1>

@* DEAD CODE — successMessage is never set to a non-null value in the current implementation.
   The StrawberryShake migration replaced the success path with Nav.NavigateTo("/users"),
   so a user is redirected before this block could ever render.

   The raw HttpClient version set successMessage = $"Registered {username}" here. That
   pattern made sense when the page stayed mounted on success. With navigation, an in-page
   success message is redundant — the user lands on /users and sees the new row.

   TODO (next branch): Remove this block and the successMessage field/clear below.
   Leaving it here as a worked example of how dead UI state accumulates during migrations.
*@
@if (successMessage is not null)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@* EditForm replaces plain <form>. It:
   - Binds to a model object (the form field values)
   - Manages validation state for each field
   - Routes submission to OnValidSubmit (only fires if validation passes)
     or OnInvalidSubmit (fires if validation fails)
*@
<EditForm Model="formModel" OnValidSubmit="HandleSubmit">
    @* DataAnnotationsValidator reads [Required], [EmailAddress], [MinLength] etc.
       from the model class and runs client-side validation on submit. *@
    <DataAnnotationsValidator />

    @* ValidationSummary renders a <ul> of all validation errors.
       Alternatively, use <ValidationMessage For="@(() => formModel.Username)" />
       next to individual fields for inline errors. *@
    <ValidationSummary />

    <div class="mb-3">
        <label for="username" class="form-label text-center">User Name</label>
        @* @bind="formModel.Username" sets up two-way binding:
           - Input changes update formModel.Username
           - formModel.Username changes update the input value
           Compare to React: value={formModel.username} onChange={e => setUsername(e.target.value)} *@
        <InputText id="username" class="form-control" @bind-Value="formModel.Username" />
    </div>

    <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <InputText id="email" class="form-control" @bind-Value="formModel.Email" />
    </div>

    <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <InputText id="password" type="password" class="form-control" @bind-Value="formModel.Password" />
    </div>

    <button type="submit" class="btn btn-success" disabled="@isSubmitting">
        @(isSubmitting ? "Registering..." : "Register")
    </button>
</EditForm>

@code {
    // The form model — EditForm binds to this object.
    // Data annotations here drive the DataAnnotationsValidator above.
    // This is the Blazor equivalent of a React form's state object.
    private RegisterForm formModel = new();

    private bool isSubmitting;
    private string? successMessage; // DEAD — never assigned after SS migration; TODO (next branch): remove
    private string? errorMessage;

    private async Task HandleSubmit()
    {
        // OnValidSubmit only fires if DataAnnotationsValidator passes —
        // so we don't need to manually check formModel.IsValid or similar.

        isSubmitting = true;
        successMessage = null; // DEAD — see field declaration above; TODO (next branch): remove
        errorMessage = null;

        try
        {
            // RegisterUserInput is a generated type from the schema's RegisterUserInput
            // definition. Its property names and types come from the schema, so it can
            // never drift from what the API expects. Compare to the old approach where
            // we serialized an anonymous object and hoped the field names matched.
            //
            // Client.RegisterUser is the generated IRegisterUserMutation.
            // ExecuteAsync(RegisterUserInput input) sends RegisterUser.graphql.
            IOperationResult<IRegisterUserResult> result = await Client.RegisterUser.ExecuteAsync(
                new RegisterUserInput
                {
                    Username = formModel.Username,
                    Email    = formModel.Email,
                    Password = formModel.Password
                });

            if (result.Errors is { Count: > 0 } topLevelErrors)
            {
                errorMessage = $"GraphQL error(s): {string.Join("; ", topLevelErrors.Select(e => e.Message))}";
                return;
            }

            // result.Data is non-null because top-level Errors was empty.
            // RegisterUser payload follows the error-as-data pattern:
            //   Success: .User is non-null, .Errors is null
            //   Failure: .User is null,     .Errors has the validation reasons
            IRegisterUser_RegisterUser payload = result.Data!.RegisterUser;

            if (payload.Errors is { Count: > 0 } validationErrors)
            {
                // e.Code is CreateUserErrorCode — a generated enum, not a string.
                // This means misspellings in code that compares error codes become
                // compile errors rather than silent mismatches at runtime.
                errorMessage = string.Join(" | ", validationErrors.Select(e => $"{e.Code}: {e.Message}"));
            }
            else if (payload.User is not null)
            {
                // Navigate to the user list so the new user is immediately visible.
                // NavigationManager.NavigateTo() is the Blazor equivalent of
                // React Router's navigate() or Next.js's router.push().
                Nav.NavigateTo("/users");
            }
            else
            {
                // Fallback: server returned HTTP 200, no top-level errors, no payload errors,
                // and no created user. Unexpected response shape — surface it explicitly.
                errorMessage = "Registration did not return a result. The user may not have been created.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    // =============================================================================
    // FORM MODEL
    //
    // A plain C# class whose properties are bound to the form inputs above.
    // Data annotations drive validation — same attributes used on EF Core models
    // or MVC view models. The DataAnnotationsValidator component reads these at
    // runtime and produces validation messages.
    //
    // TODO: Consider extracting this to a separate Models/ file once it grows.
    // =============================================================================

    private class RegisterForm
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Username is required")]
        [System.ComponentModel.DataAnnotations.MinLength(3, ErrorMessage = "Username must be at least 3 characters")]
        public string Username { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Enter a valid email address")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required")]
        [System.ComponentModel.DataAnnotations.MinLength(8, ErrorMessage = "Password must be at least 8 characters")]
        public string Password { get; set; } = string.Empty;
    }
}
