{
  // StrawberryShake client configuration.
  //
  // "schema" points at schema.graphql in the repo root (one level up from this project).
  // That file is auto-generated by the API's ExportSchema MSBuild target on every
  // Debug build — so it always reflects the current C# type definitions.
  //
  // "documents" is a glob that picks up all *.graphql operation files in this project.
  // Each file generates a typed method on the client (GetUsersAsync, RegisterUserAsync, etc.).
  //
  // StrawberryShake's Roslyn analyzer reads this config at build time and generates
  // C# source files in the obj/ folder. You never see or edit the generated code —
  // you just call the typed methods. If the schema changes and a field you're using
  // disappears, you get a compile error, not a runtime 404.
  "schema": "../schema.graphql",
  "documents": "./GraphQL/**/*.graphql",
  "extensions": {
    "strawberryShake": {
      "name": "MyTowerClient",
      "namespace": "MyTowerRegistration.Admin.GraphQL",
      "url": "http://localhost:5026/api/graphql",
      "dependencyInjection": true
    }
  }
}
