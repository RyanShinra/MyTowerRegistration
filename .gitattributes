###############################################################################
# Default: normalize all text files to LF in the repository.
# Git auto-detects text vs binary; explicit rules below override per pattern.
###############################################################################
* text=auto eol=lf

# ── .NET / C# ────────────────────────────────────────────────────────────────
*.cs       text eol=lf
*.csproj   text eol=lf
*.sln      text eol=lf
*.razor    text eol=lf
*.cshtml   text eol=lf

# ── MSBuild ──────────────────────────────────────────────────────────────────
*.props    text eol=lf
*.targets  text eol=lf

# ── Data / config formats ────────────────────────────────────────────────────
*.json        text eol=lf
*.xml         text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.config      text eol=lf
*.editorconfig text eol=lf
*.resx        text eol=lf

# ── Web / frontend ───────────────────────────────────────────────────────────
*.html  text eol=lf
*.htm   text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.sass  text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.jsx   text eol=lf

# ── GraphQL ──────────────────────────────────────────────────────────────────
*.graphql text eol=lf

# ── Documentation / plain text ───────────────────────────────────────────────
*.md  text eol=lf
*.txt text eol=lf
*.svg text eol=lf

# ── Scripts ──────────────────────────────────────────────────────────────────
*.sh   text eol=lf
*.ps1  text eol=lf
*.psm1 text eol=lf

# ── Docker ───────────────────────────────────────────────────────────────────
Dockerfile*    text eol=lf
*.dockerignore text eol=lf

# ── Git / environment ────────────────────────────────────────────────────────
.gitignore text eol=lf
*.env      text eol=lf
.env.*     text eol=lf

# ── Binary — never diff or merge as text ─────────────────────────────────────
*.dll binary
*.exe binary
*.png binary
*.jpg binary
*.ico binary

