{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "HotChocolate": "Debug"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=mytower;Username=postgres;Password=..."
  },

  // Origins allowed to make cross-origin requests to this API in local dev.
  // These match the Blazor Admin dev server ports from launchSettings.json.
  // In production, AllowedOrigins__0 is injected as an ECS task definition
  // environment variable — no appsettings change needed.
  "AllowedOrigins": [
    "http://localhost:5273",
    "https://localhost:7298"
  ]
}
